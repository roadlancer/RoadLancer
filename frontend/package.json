{
  "name": "roadlancer-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "DATABASE_URL=postgresql://postgres:postgres@localhost:5433/roadlancer_test playwright test",
    "test:e2e:ui": "DATABASE_URL=postgresql://postgres:postgres@localhost:5433/roadlancer_test playwright test --ui",
    "test:e2e:headed": "DATABASE_URL=postgresql://postgres:postgres@localhost:5433/roadlancer_test playwright test --headed",
    "test:setup": "npx tsx tests/global-setup.ts"
  },
  "dependencies": {
    "@lucide/vue": "^1.22.0",
    "@noble/hashes": "^2.2.0",
    "@tanstack/vue-query": "^5.101.2",
    "@vuehookform/core": "^0.7.0",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.9.0",
    "better-auth": "^1.6.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "reka-ui": "^2.10.1",
    "shadcn-vue": "^2.7.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.16",
    "vue-router": "^4.5.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.1.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.5.2",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^24.0.3",
    "@vitejs/plugin-vue": "^5.2.4",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.10"
  }
}
