# General
APP_NAME=RoadLancer
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=roadlancer
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Cache & Sessions (No Redis needed)
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120

# AI Microservice
AI_SERVICE_URL=http://localhost:8001

# Mail (logged to storage/logs, no real email)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@roadlancer.in
MAIL_FROM_NAME="${APP_NAME}"
