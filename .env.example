# General
APP_NAME=RoadLancer
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database (PostgreSQL + PostGIS)
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=roadlancer
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=null

# Cache, Queue & Sessions
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

# AI Microservice
AI_SERVICE_URL=http://localhost:8001

# External Services (Exotel SMS & Calling)
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_SID=your_exotel_sid
EXOTEL_EXOPHONE=08041234567

# External Services (Razorpay)
RAZORPAY_KEY_ID=rzp_test_123456789
RAZORPAY_KEY_SECRET=your_razorpay_secret

# External Services (Google Maps)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Mail (for notifications)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@roadlancer.in
MAIL_FROM_NAME="${APP_NAME}"
