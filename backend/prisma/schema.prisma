generator client {
  provider                  = "prisma-client-py"
  enable_experimental_decimal = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === Auth tables (managed by Better Auth, read-only here) ===

enum Role {
  driver
  shipper
  admin
}

enum UserStatus {
  pending
  approved
  rejected
}

enum VerificationStatus {
  pending
  approved
  rejected
}

model user {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  role          Role       @default(driver)
  phone         String?
  suspended     Boolean    @default(false)
  status        UserStatus @default(approved)

  session         session[]
  account         account[]
  shipments       shipments[] @relation("Shipper")
  assignedShipments shipments[] @relation("Driver")
  bids            bids[]
  verification    user_verifications?
  supportTickets  support_tickets[]

  @@map("user")
}

model session {
  id           String   @id
  expiresAt    DateTime @map("expires_at")
  token        String   @unique
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  userId       String   @map("user_id")
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("account")
}

model auth_verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verification")
}

// === Business tables ===

model shipments {
  id               String    @id @default(uuid())
  shipperId        String    @map("shipper_id")
  title            String
  goodsCategory    String    @map("goods_category")
  weightKg         Decimal   @map("weight_kg") @db.Decimal(10, 2)
  pickupAddress    String    @map("pickup_address")
  dropoffAddress   String    @map("dropoff_address")
  distanceKm       Decimal   @map("distance_km") @db.Decimal(10, 2)
  vehicleType      String    @map("vehicle_type")
  aiFloorPrice     Decimal?  @map("ai_floor_price") @db.Decimal(10, 2)
  aiEstimatedMin   Decimal?  @map("ai_estimated_min") @db.Decimal(10, 2)
  aiEstimatedMax   Decimal?  @map("ai_estimated_max") @db.Decimal(10, 2)
  shipperBudget    Decimal?  @map("shipper_budget") @db.Decimal(10, 2)
  isForcedPrice    Boolean   @default(false) @map("is_forced_price")
  status           String    @default("draft")
  assignedDriverId String?   @map("assigned_driver_id")
  biddingEndsAt    DateTime? @map("bidding_ends_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  shipper        user    @relation("Shipper", fields: [shipperId], references: [id], onDelete: Cascade)
  assignedDriver user?   @relation("Driver", fields: [assignedDriverId], references: [id], onDelete: SetNull)
  bids           bids[]
  verifications  verifications[]

  @@map("shipments")
}

model bids {
  id         String   @id @default(uuid())
  shipmentId String   @map("shipment_id")
  driverId   String   @map("driver_id")
  amount     Decimal  @db.Decimal(10, 2)
  message    String?
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  shipment shipments @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  driver   user      @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("bids")
}

model verifications {
  id         String    @id @default(uuid())
  shipmentId String    @map("shipment_id")
  type       String
  otpCode    String    @map("otp_code")
  isVerified Boolean   @default(false) @map("is_verified")
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  shipment shipments @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("verifications")
}

// === User verification (driver/shipper profile verification) ===

model user_verifications {
  id              String             @id @default(uuid())
  userId          String             @unique @map("user_id")
  user            user               @relation(fields: [userId], references: [id], onDelete: Cascade)

  // === Common fields ===
  fullName              String?      @map("full_name")
  fatherName            String?      @map("father_name")
  dateOfBirth           DateTime?    @map("date_of_birth")
  bloodGroup            String?      @map("blood_group")
  aadhaarLast4          String?      @map("aadhaar_last4")
  address               String?
  phone                 String?
  emergencyContactName  String?      @map("emergency_contact_name")
  emergencyContactPhone String?      @map("emergency_contact_phone")
  profilePhoto          String?      @map("profile_photo")
  aadhaarPhoto          String?      @map("aadhaar_photo")

  // === Driver-specific fields ===
  licenseNumber         String?      @map("license_number")
  dlExpiryDate          DateTime?    @map("dl_expiry_date")
  dlCategory            String?      @map("dl_category")
  vehicleRegNumber      String?      @map("vehicle_reg_number")
  vehicleType           String?      @map("vehicle_type")
  vehicleMakeModel      String?      @map("vehicle_make_model")
  vehicleYear           Int?         @map("vehicle_year")
  insurancePolicyNumber String?      @map("insurance_policy_number")
  insuranceProvider     String?      @map("insurance_provider")
  insuranceExpiryDate   DateTime?    @map("insurance_expiry_date")
  pucCertificateNumber  String?      @map("puc_certificate_number")
  pucExpiryDate         DateTime?    @map("puc_expiry_date")
  dlPhoto               String?      @map("dl_photo")
  rcBookPhoto           String?      @map("rc_book_photo")
  insurancePhoto        String?      @map("insurance_photo")

  // === Shipper-specific fields ===
  businessName          String?      @map("business_name")
  businessType          String?      @map("business_type")
  gstNumber             String?      @map("gst_number")
  panNumber             String?      @map("pan_number")
  registeredAddress     String?      @map("registered_address")
  annualTurnover        String?      @map("annual_turnover")
  yearsInBusiness       Int?         @map("years_in_business")
  primaryGoodsCategory  String?      @map("primary_goods_category")
  gstCertPhoto          String?      @map("gst_cert_photo")
  panCardPhoto          String?      @map("pan_card_photo")
  businessRegPhoto      String?      @map("business_reg_photo")

  // === AI Verification (Phase 2 — columns pre-created) ===
  aiVerificationScore   Float?       @map("ai_verification_score")
  aiVerificationResult  String?      @map("ai_verification_result")
  aiVerifiedAt          DateTime?    @map("ai_verified_at")
  aiAutoRejected        Boolean      @default(false) @map("ai_auto_rejected")

  // === Status & Review ===
  status          VerificationStatus @default(pending)
  reviewedBy      String?            @map("reviewed_by")
  reviewedAt      DateTime?          @map("reviewed_at")
  rejectionReason String?            @map("rejection_reason")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@map("user_verifications")
}

model support_tickets {
  id           String   @id @default(uuid())
  ticketNumber String   @unique @map("ticket_number")
  senderEmail  String   @map("sender_email")
  senderName   String?  @map("sender_name")
  subject      String
  message      String
  category     String   @default("general")
  status       String   @default("open")
  priority     String   @default("normal")
  source       String   @default("email")
  userId       String?  @map("user_id")
  adminNotes   String?  @map("admin_notes")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user    user?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  replies ticket_replies[]

  @@map("support_tickets")
}

model ticket_replies {
  id         String   @id @default(uuid())
  ticketId   String   @map("ticket_id")
  senderName String   @map("sender_name")
  senderRole String   @map("sender_role") // "admin" or "user"
  senderType String   @map("sender_type") // "agent" or "customer"
  message    String
  createdAt  DateTime @default(now()) @map("created_at")

  ticket support_tickets @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_replies")
}

